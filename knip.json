{
	"$schema": "https://unpkg.com/knip@5/schema.json",
	"ignoreDependencies": ["cloudflare", "@vitest/coverage-v8"],
	"workspaces": {
		".": {
			"entry": ["scripts/*.ts", "taze.config.ts"]
		},
		"apps/data-service": {
			"ignore": ["src/durable-objects/**", "src/workflows/**"]
		},
		"packages/data-ops": {
			"entry": ["src/*/index.ts", "src/auth/*.ts", "config/auth.ts", "drizzle-*.config.ts"],
			"ignoreBinaries": ["dotenvx"]
		}
	}
}
